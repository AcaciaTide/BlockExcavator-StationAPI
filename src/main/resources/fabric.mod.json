{
  "schemaVersion": 1,
  "id": "blockexcavatorstapi",
  "version": "${version}",

  "name": "Block Excavator StationAPI",
  "description": "A vein mining mod for Minecraft Beta 1.7.3 with multiple mining modes.",
  "authors": [
    "AcaciaTide"
  ],
  "contact": {
    "sources": "https://github.com/acaciatide/stapi-excavator"
  },

  "license": "MIT",
  "icon": "assets/blockexcavatorstapi/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "io.github.acaciatide.blockexcavatorstapi.events.init.InitListener",
      "io.github.acaciatide.blockexcavatorstapi.events.init.PacketRegistrationListener"
    ],
    "stationapi:event_bus_client": [
      "io.github.acaciatide.blockexcavatorstapi.events.init.ClientInitListener"
    ],
    "gcapi3": [
      "io.github.acaciatide.blockexcavatorstapi.config.ConfigInit"
    ]
  },
  "mixins": [
    "blockexcavatorstapi.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "stationapi": ">=2.0.0-alpha.1",
    "gcapi3": ">=3.0.0"
  }
}
