{
  "schemaVersion": 1,
  "id": "stapiultimine",
  "version": "${version}",

  "name": "StAPI Ultimine",
  "description": "A vein mining mod for Minecraft Beta 1.7.3 with multiple mining modes.",
  "authors": [
    "AcaciaTide"
  ],
  "contact": {
    "sources": "https://github.com/acaciatide/stapi-ultimine"
  },

  "license": "MIT",
  "icon": "assets/stapiultimine/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "io.github.acaciatide.stapiultimine.events.init.InitListener",
      "io.github.acaciatide.stapiultimine.events.init.PacketRegistrationListener"
    ],
    "stationapi:event_bus_client": [
      "io.github.acaciatide.stapiultimine.events.init.ClientInitListener"
    ],
    "gcapi3": [
      "io.github.acaciatide.stapiultimine.config.ConfigInit"
    ]
  },
  "mixins": [
    "stapiultimine.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3"
  }
}
